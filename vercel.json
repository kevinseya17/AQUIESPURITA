{
  "version": 2,
  "builds": [
    {
      "src": "ms_gateway.py",
      "use": "@vercel/python"
    },
    {
      "src": "login/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.10" }
    }
  ],
  "routes": [
    {
      "src": "/api/ms-login(.*)",
      "dest": "ms_gateway.py"
    },
    {
      "src": "/(.*)",
      "dest": "login/wsgi.py"
    }
  ]
}
